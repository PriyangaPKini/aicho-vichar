---
import BaseLayout from '../layouts/BaseLayout.astro';
import Search from '../components/search/Search.astro';
import ShelfListItem from '../components/shelf/ShelfListItem.astro';
import { getSortedCollection } from '../lib/content';
import { shelfToSearchItem } from '../lib/search';

const shelf = await getSortedCollection('shelf');
const searchItems = shelf.map(shelfToSearchItem);
---

<BaseLayout title="Shelf — Priyanga P Kini" description="Books, talks, articles, and podcasts I keep recommending.">
  <section class="intro intro-shelf">
    <h1 class="page-title">The <em>Shelf</em></h1>
    <p>Books, talks, articles, and podcasts I keep coming back to.</p>
  </section>

  <Search
    items={searchItems}
    label="Shelf"
    placeholder="Search shelf..."
    triggerText="Search shelf…"
  />

  <ul class="post-list">
    {shelf.map((item) => (
      <ShelfListItem item={item} />
    ))}
  </ul>
</BaseLayout>

<style>
  .intro-shelf {
    margin-bottom: 1.25rem;
  }

  .intro-shelf h1 {
    margin-bottom: 0.75rem;
  }
</style>

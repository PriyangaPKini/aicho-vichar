---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SignInModal from '../../components/SignInModal.astro';
import SignUpModal from '../../components/SignUpModal.astro';
import Comments from '../../components/Comments.astro';
import { getCollection, render } from 'astro:content';
import { splitTitleEmphasis } from '../../utils';

export async function getStaticPaths() {
  const posts = (await getCollection('blog'))
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
  
  return posts.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: index < posts.length - 1 ? posts[index + 1] : null,
      next: index > 0 ? posts[index - 1] : null,
    },
  }));
}

const { post, prev, next } = Astro.props;

const { Content, headings } = await render(post);
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
const canonicalUrl = post.data.canonicalUrl;
const canonicalSource = canonicalUrl
  ? new URL(canonicalUrl).hostname.replace(/^www\./, '')
  : null;
const { head, em } = splitTitleEmphasis(post.data.title, post.data.titleEmphasis);
---

<BaseLayout title={`${post.data.title} — Priyanga P Kini`} description={post.data.description}>
  {toc.length > 0 && (
    <aside class="toc" data-toc aria-label="Table of contents">
      <p class="toc-label">On this page</p>
      <ul>
        {toc.map((h) => (
          <li class={`toc-${h.depth}`}>
            <a href={`#${h.slug}`}>{h.text}</a>
          </li>
        ))}
      </ul>
    </aside>
  )}

  <section class="intro intro-post">
    <h1 class="page-title">{head}{em && <> <em>{em}</em></>}</h1>
    <p class="post-item-date">
      {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    </p>
  </section>

  <article class="prose" data-blog-content>
    <Content />
    {canonicalUrl && (
      <p class="post-canonical">
        Originally published on{' '}
        <a href={canonicalUrl} target="_blank" rel="noopener noreferrer">
          {canonicalSource}
        </a>.
      </p>
    )}
  </article>

  <Comments postSlug={post.id} />

  <SignInModal />
  <SignUpModal />

  <nav class="post-navigation">
    <div class="nav-prev">
      {prev ? (
        <a href={`/blog/${prev.id}`}>← {prev.data.title}</a>
      ) : (
        <span></span>
      )}
    </div>
    <div class="nav-next">
      {next ? (
        <a href={`/blog/${next.id}`}>{next.data.title} →</a>
      ) : (
        <span></span>
      )}
    </div>
  </nav>
</BaseLayout>

<script>
  const toc = document.querySelector<HTMLElement>('[data-toc]');
  const blogContent = document.querySelector<HTMLElement>('[data-blog-content]');

  if (toc && blogContent) {
    const updateTocVisibility = () => {
      const contentRect = blogContent.getBoundingClientRect();
      const tocRect = toc.getBoundingClientRect();
      const isReadingContent = contentRect.top < window.innerHeight && contentRect.bottom > tocRect.top;
      toc.classList.toggle('is-hidden', !isReadingContent);
    };

    updateTocVisibility();
    window.addEventListener('scroll', updateTocVisibility, { passive: true });
    window.addEventListener('resize', updateTocVisibility);
  }
</script>

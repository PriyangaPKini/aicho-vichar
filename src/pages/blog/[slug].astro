---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SignInModal from '../../components/auth/SignInModal.astro';
import SignUpModal from '../../components/auth/SignUpModal.astro';
import Comments from '../../components/comments/Comments.astro';
import CanonicalCallout from '../../components/blog/CanonicalCallout.astro';
import PostHeader from '../../components/blog/PostHeader.astro';
import PostNavigation from '../../components/blog/PostNavigation.astro';
import TableOfContents from '../../components/blog/TableOfContents.astro';
import { render } from 'astro:content';
import { getSortedCollection } from '../../lib/content';

export async function getStaticPaths() {
  const posts = await getSortedCollection('blog');

  return posts.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: index < posts.length - 1 ? posts[index + 1] : null,
      next: index > 0 ? posts[index - 1] : null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await render(post);
---

<BaseLayout title={`${post.data.title} — Priyanga P Kini`} description={post.data.description}>
  <TableOfContents headings={headings} />

  <PostHeader
    title={post.data.title}
    date={post.data.date}
    titleEmphasis={post.data.titleEmphasis}
  />

  <article class="prose" data-blog-content>
    <Content />
    <CanonicalCallout url={post.data.canonicalUrl} />
  </article>

  <Comments postSlug={post.id} />

  <SignInModal />
  <SignUpModal />

  <PostNavigation prev={prev} next={next} />
</BaseLayout>

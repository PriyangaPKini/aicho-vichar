---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogListItem from '../../components/blog/BlogListItem.astro';
import Search from '../../components/search/Search.astro';
import { getSortedCollection } from '../../lib/content';

const posts = await getSortedCollection('blog');
---

<BaseLayout title="All Blogs — Priyanga P Kini">
<section class="intro intro-large">
  <h1 class="page-title">All <em>Vichars</em></h1>
</section>
<Search />
  {posts.length === 0 ? (
    <p style="color: var(--text-muted);">No blogs yet. Stay tuned.</p>
  ) : (
    <ul class="post-list">
      {posts.map((post, i) => (
        <BlogListItem post={post} index={i} variant="detailed" />
      ))}
    </ul>
  )}
</BaseLayout>

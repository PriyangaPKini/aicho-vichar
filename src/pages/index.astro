---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogListItem from '../components/blog/BlogListItem.astro';
import { HOME_LATEST_BLOG_LIMIT } from '../constants';
import { getLatestBlogPosts } from '../lib/content';

const posts = await getLatestBlogPosts(HOME_LATEST_BLOG_LIMIT);
---

<BaseLayout>
  <figure class="cover">
    <img src="/gallery/holiday-in-munnar.jpeg" alt="Holiday in Munnar" />
    <figcaption>Holiday in Munnar</figcaption>
  </figure>

  <section class="intro intro-large">
<h1 class="page-title"> I'm <em> Priyanga Kini </em></h1>
    <p>I build and consult on software for a living.</p>
    <p>I'm a member of <a href="https://nilenso.com" target="_blank" rel="noopener noreferrer" class="link-gold">nilenso</a>, an employee-owned software co-op, so the job sits across engineering, consulting, and helping run the place.</p>
    <p>I share reflections on work and life here.</p>
  </section>

  {posts.length > 0 && (
    <section class="section">
      <div class="section-title">
        <span>Latest Blogs</span>
      </div>
      <ul class="post-list">
        {posts.map((post, i) => (
          <BlogListItem post={post} index={i} />
        ))}
      </ul>
      <p class="section-more">
        <a href="/blog">View all &rarr;</a>
      </p>
    </section>
  )}
</BaseLayout>

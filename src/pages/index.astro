---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostItem from '../components/PostItem.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);
---

<BaseLayout>
  <section class="intro">
    <h1 class="page-title">Namaskaaru, <em>I'm Priyanga </em></h1>
    <p>This is my personal blog, so it's a bit of everything: notes from work, books I'm reading, people I'm meeting, conversations that stay with me, and the slow business of figuring out how to live.</p>
    <div class="intro-links">
      <a href="/blog">Blogs</a>
      <a href="/about">More about me</a>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="section">
      <div class="section-title">
        <span>Latest Posts</span>
        <a href="/blog">View all &rarr;</a>
      </div>
      <ul class="post-list">
        {posts.map((post, i) => (
          <PostItem post={post} index={i} />
        ))}
      </ul>
    </section>
  )}
</BaseLayout>

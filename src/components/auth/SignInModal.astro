---
---

<div class="signin-overlay" id="signinOverlay" role="dialog" aria-modal="true" aria-labelledby="signinTitle">
  <div class="signin-modal">
    <button class="signin-close" id="signinClose" aria-label="Close">&times;</button>
    <img class="signin-avatar" src="/avatar.jpg" alt="" />
    <h2 id="signinTitle">Aicho <em>Vichar</em></h2>
    <p class="signin-sub">Welcome back.</p>
    <button type="button" class="signin-google" id="signinGoogle">
      <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
        <path fill="#4285F4" d="M17.64 9.2c0-.64-.06-1.25-.16-1.84H9v3.48h4.84a4.14 4.14 0 0 1-1.8 2.71v2.26h2.9c1.7-1.57 2.7-3.88 2.7-6.61z"/>
        <path fill="#34A853" d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.9-2.26c-.8.54-1.83.86-3.06.86-2.35 0-4.34-1.58-5.05-3.7H.96v2.34A9 9 0 0 0 9 18z"/>
        <path fill="#FBBC05" d="M3.95 10.72A5.4 5.4 0 0 1 3.66 9c0-.6.1-1.18.29-1.72V4.94H.96A9 9 0 0 0 0 9c0 1.45.35 2.83.96 4.06l2.99-2.34z"/>
        <path fill="#EA4335" d="M9 3.58c1.32 0 2.5.45 3.44 1.35l2.58-2.59C13.46.9 11.42 0 9 0A9 9 0 0 0 .96 4.94L3.95 7.28C4.66 5.16 6.65 3.58 9 3.58z"/>
      </svg>
      <span>Continue with Google</span>
    </button>
    <p class="signin-error" id="signinError"></p>
    <p class="signin-switch">Don't have an account? <a href="#" data-open-signup>Sign up</a></p>
  </div>
</div>

<script>
  import { signInWithGoogle } from '../../lib/firebase';

  const overlay = document.getElementById('signinOverlay');
  const closeBtn = document.getElementById('signinClose');
  const triggers = document.querySelectorAll('[data-open-signin]');
  const googleBtn = document.getElementById('signinGoogle');
  const errorEl = document.getElementById('signinError');

  function open() {
    if (errorEl) errorEl.textContent = '';
    overlay?.classList.add('open');
  }

  function close() {
    overlay?.classList.remove('open');
  }

  googleBtn?.addEventListener('click', async () => {
    if (errorEl) errorEl.textContent = '';
    try {
      await signInWithGoogle();
      close();
      window.dispatchEvent(new CustomEvent('site:notice', { detail: 'Signed in successfully.' }));
    } catch (err) {
      if (errorEl) errorEl.textContent = (err as Error)?.message ?? 'Sign-in failed.';
    }
  });

  triggers.forEach((t) => t.addEventListener('click', (e) => {
    e.preventDefault();
    document.getElementById('signupOverlay')?.classList.remove('open');
    open();
  }));

  closeBtn?.addEventListener('click', close);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) close();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay?.classList.contains('open')) close();
  });
</script>

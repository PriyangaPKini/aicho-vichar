---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{toc.length > 0 && (
  <aside class="toc" data-toc aria-label="Table of contents">
    <p class="toc-label">On this page</p>
    <ul>
      {toc.map((h) => (
        <li class={`toc-${h.depth}`}>
          <a href={`#${h.slug}`}>{h.text}</a>
        </li>
      ))}
    </ul>
  </aside>
)}

<script>
  const toc = document.querySelector<HTMLElement>('[data-toc]');
  const blogContent = document.querySelector<HTMLElement>('[data-blog-content]');

  if (toc && blogContent) {
    const updateTocVisibility = () => {
      const contentRect = blogContent.getBoundingClientRect();
      const tocRect = toc.getBoundingClientRect();
      const isReadingContent = contentRect.top < window.innerHeight && contentRect.bottom > tocRect.top;
      toc.classList.toggle('is-hidden', !isReadingContent);
    };

    updateTocVisibility();
    window.addEventListener('scroll', updateTocVisibility, { passive: true });
    window.addEventListener('resize', updateTocVisibility);
  }
</script>

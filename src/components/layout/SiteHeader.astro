---
const { currentPath = "" } = Astro.props;
const isActive = (path: string) =>
  currentPath === path || currentPath === `${path}/`;
---

<header class="site-header">
  <div class="site-header-inner">
    <nav class="site-header-nav" aria-label="Primary navigation">
      <a href="/" class={`site-header-link site-header-home${isActive("/") ? " is-active" : ""}`} title="Home" aria-label="Home">
        <svg width="20" height="20" aria-hidden="true">
          <use href="#icon-home" />
        </svg>
      </a>
      <a href="/blog" class={`site-header-link${isActive("/blog") ? " is-active" : ""}`}>Blogs</a>
      <a href="/shelf" class={`site-header-link${isActive("/shelf") ? " is-active" : ""}`}>Shelf</a>
    </nav>
  </div>
</header>
